APP_NAME=Mock API
APP_VERSION=1.0.0
ENVIRONMENT=development
API_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8000
RELOAD=true
DOCS_ENABLED=true

LOG_LEVEL=INFO
LOG_JSON=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/mock_api

OTEL_ENABLED=false
OTEL_SERVICE_NAME=mock-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

